class Node {
public:
    int key, val;
    Node *prev, *next;

    Node(int k, int v) {
        key = k;
        val = v;
        prev = next = NULL;
    }
};

class LRUCache {
public:
    int cap;
    unordered_map<int, Node*> mp;

    Node *head, *tail;

    LRUCache(int capacity) {
        cap = capacity;

        head = new Node(-1, -1);
        tail = new Node(-1, -1);

        head->next = tail;
        tail->prev = head;
    }

    void deleteNode(Node *node) {
        Node *prevNode = node->prev;
        Node *nextNode = node->next;

        prevNode->next = nextNode;
        nextNode->prev = prevNode;
    }

    void insertFront(Node *node) {
        Node *temp = head->next;

        node->next = temp;
        node->prev = head;

        head->next = node;
        temp->prev = node;
    }

    int get(int key) {

        if (mp.find(key) == mp.end())
            return -1;

        Node *node = mp[key];

        deleteNode(node);
        insertFront(node);

        return node->val;
    }

    void put(int key, int value) {

        if (mp.find(key) != mp.end()) {

            Node *node = mp[key];
            node->val = value;

            deleteNode(node);
            insertFront(node);

            return;
        }

        if (mp.size() == cap) {

            Node *lru = tail->prev;

            mp.erase(lru->key);

            deleteNode(lru);
        }

        Node *node = new Node(key, value);

        insertFront(node);

        mp[key] = node;
    }
};

