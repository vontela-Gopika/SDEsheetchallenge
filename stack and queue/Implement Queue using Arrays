#include<bits/stdc++.h>
using namespace std;
class implementation{
    int start = -1, end = -1;
    int curr = 0;
    static const int n = 10;
    int q[n];
public:
    void push(int x){
        if(curr == n){
            cout << -1 << endl;
            return;
        }
        if(start == -1){
            start = 0;
            end = 0;
        }
        else{
            end = (end + 1) % n;
        }
        q[end] = x;
        curr++;
    }
    void pop(){
        if(curr == 0){
            cout << -1 << endl;
            return;
        }
        int el = q[start];
        if(curr == 1){
            start = -1;
            end = -1;
        }
        else{
            start = (start + 1) % n;
        }
        curr--;
        cout << el << endl;
    }
    void top(){
        if(curr == 0){
            cout << -1 << endl;
            return;
        }
        cout << q[start] << endl;
    }
    void size(){
        cout << curr << endl;
    }
};
int main(){
    implementation q;
    int n;
    cin >> n;
    while(n--){
        string op;
        cin >> op;
        if(op == "push"){
            int x;
            cin >> x;
            q.push(x);
        }
        else if(op == "pop"){
            q.pop();
        }
        else if(op == "top"){
            q.top();
        }
        else if(op == "size"){
            q.size();
        }
    }
}
