class Solution {
public:
    vector<int> inorderTraversal(TreeNode* root) {
        vector<int> arr;
        TreeNode* curr=root;
        while(curr!=NULL){
            if(curr->left==nullptr){
                arr.push_back(curr->val);
                curr=curr->right;
            }else{
                TreeNode* prev=curr->left;
                while(prev->right && prev->right!=curr){
                    prev=prev->right;
                }
                if(prev->right==nullptr){
                    prev->right=curr;
                    curr=curr->left;
                }else{
                    prev->right=nullptr;
                    arr.push_back(curr->val);
                    curr=curr->right;
                }
            }
        }
        return arr;
    }
};
