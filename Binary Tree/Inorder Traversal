class Solution {
public:
    vector<int> inorderTraversal(TreeNode* root) {

        vector<int> arr;
        stack<TreeNode*> st;
        TreeNode* curr = root;

        while (curr != nullptr || !st.empty()) {

            while (curr != nullptr) {
                st.push(curr);
                curr = curr->left;
            }

            curr = st.top();
            st.pop();

            arr.push_back(curr->val);

            curr = curr->right;
        }

        return arr;
    }
};
