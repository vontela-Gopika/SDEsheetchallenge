class Solution {
public:
    int lengthOfLongestSubstring(string s) {
        int maxlen=0;


        unordered_map<char,int> mp;
        int left=0;
        int len=0;
        for(int right=0;right<s.length();right++){
            if(mp.find(s[right])!=mp.end()){
                left=max(left,mp[s[right]]);
            }
            
            mp[s[right]]=right+1;
           
            len=max(len,right-left+1);

        }
        return len;
    }
};
