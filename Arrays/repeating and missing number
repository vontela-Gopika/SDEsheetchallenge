#include<bits/stdc++.h>
using namespace std;
vector<int> repeatingandmissing(vector<int> &a){
    int n=a.size();
    int sn=(n*(n+1))/2;
    int s2n=(n*(n+1)*(2*n+1))/6;
    int s=0,s2=0;
    for(int i=0;i<n;i++){
        s+=a[i];
        s2+=a[i]*a[i];
    }
    int va1=s-sn;
    int val2=(s2-s2n)/va1;
    int x=(va1+val2)/2;
    int y=x-va1;
    return {x,y};
}
int main(){
    vector<int> a;
    string s;
    getline(cin,s);
    stringstream ss(s);
    int x;
    while(ss>> x) a.push_back(x);
    vector<int> t=repeatingandmissing(a);
    for(int i=0;i<t.size();i++){
        cout<<t[i]<<" ";
    }
