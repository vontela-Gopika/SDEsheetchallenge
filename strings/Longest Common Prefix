class Solution {
public:
    string longestCommonPrefix(vector<string>& strs) {
        if(strs.empty()) return "";
        sort(strs.begin(),strs.end());
        int n=strs.size()-1;
        string first=strs[0];
        string last=strs[n];
        string ans="";
        int minlength=min(first.size(),last.size());
        for(int i=0;i<minlength;i++){
            if(first[i]!=last[i]) break;
            ans+=first[i];
        }
        return ans;
        
    }
};
