class Solution {
public:
    bool isAnagram(string s, string t) {
        if(s.length()!=t.length()) return false;
        vector<int> freq(26,0);
        for(int i=0;i<s.length();i++){
            freq[s[i]-'a']++;
        }
        for(int i=0;i<s.length();i++){
            freq[t[i]-'a']--;
        }
        for(auto& it:freq){
            if(it>0){
                return false;
            }
        }
        return true;
     
        
    }
};
