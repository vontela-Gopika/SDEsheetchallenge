class Solution {
public:
    int romanToInt(string s) {
        unordered_map<char,int> r={
            {'I', 1}, {'V', 5}, {'X', 10},
            {'L', 50}, {'C', 100}, {'D', 500}, {'M', 1000}
        };
        int res=0;
        for(int i=0;i<s.size()-1;i++){
            if(r[s[i]]<r[s[i+1]]){
                res-=r[s[i]];
            }else{
                res+=r[s[i]];
            }
        }
        return res+r[s.back()];
        
    }
};
