class Solution {
public:
    void solve(vector<int> &candidates,int tar,vector<vector<int>> &res,int idx,int n,vector<int> &ds){
        if(idx==n){
            if(tar==0){
                res.push_back(ds);
                return;
            }else return;
        }
        if(candidates[idx]<=tar){
            ds.push_back(candidates[idx]);
            solve(candidates,tar-candidates[idx],res,idx,n,ds);
            ds.pop_back();
        }
        solve(candidates,tar,res,idx+1,n,ds);
    }
    vector<vector<int>> combinationSum(vector<int>& candidates, int target) {
        vector<vector<int>> res;
        int n=candidates.size();
        vector<int> ds;
        solve(candidates,target,res,0,n,ds);
        return res;
    }
};
